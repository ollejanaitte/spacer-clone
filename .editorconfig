# EditorConfig is awesome: https://EditorConfig.org
# Keeps encoding and indentation consistent across editors so the language
# policy on UTF-8 source files is preserved on every workstation.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.py]
end_of_line = lf
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.ps1]
end_of_line = crlf

[*.bat]
end_of_line = crlf

[*.cmd]
end_of_line = crlf
