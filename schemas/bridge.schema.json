{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spacer-clone.local/schemas/bridge.schema.json",
  "title": "Bridge Domain Model",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "schemaVersion",
    "crossSection",
    "spans",
    "impactFactor",
    "lines",
    "loads",
    "generationSettings"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "schemaVersion": { "const": "0.1.0" },
    "description": { "type": "string" },
    "createdAt": { "type": "string" },
    "updatedAt": { "type": "string" },
    "crossSection": { "$ref": "#/$defs/crossSection" },
    "spans": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/span" }
    },
    "impactFactor": { "$ref": "#/$defs/impactFactor" },
    "lines": {
      "type": "array",
      "items": { "$ref": "#/$defs/line" }
    },
    "loads": {
      "type": "array",
      "items": { "$ref": "#/$defs/load" }
    },
    "generationSettings": { "$ref": "#/$defs/generationSettings" },
    "generatedFem": { "$ref": "#/$defs/generatedFem" }
  },
  "$defs": {
    "crossSection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lane_count", "lane_width", "median_width", "sidewalk_width", "barrier_width"],
      "properties": {
        "lane_count": { "type": "integer", "minimum": 1, "maximum": 6 },
        "lane_width": { "type": "number", "exclusiveMinimum": 0 },
        "median_width": { "type": "number", "minimum": 0 },
        "sidewalk_width": { "type": "number", "minimum": 0 },
        "barrier_width": { "type": "number", "minimum": 0 }
      }
    },
    "span": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index", "length", "offset"],
      "properties": {
        "index": { "type": "integer", "minimum": 1 },
        "length": { "type": "number", "exclusiveMinimum": 0 },
        "offset": { "type": "number", "minimum": 0 }
      }
    },
    "impactFactor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "auto"],
      "properties": {
        "value": { "type": "number", "minimum": 0, "maximum": 1 },
        "auto": { "type": "boolean" },
        "formula": { "type": "string" }
      }
    },
    "line": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "name", "points"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "enum": ["traffic", "load", "reference"] },
        "name": { "type": "string" },
        "points": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": { "type": "number" }
          }
        }
      }
    },
    "load": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "name", "magnitude", "direction"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "enum": ["self_weight", "distributed", "vehicle"] },
        "name": { "type": "string" },
        "magnitude": { "type": "number" },
        "direction": { "enum": ["X", "Y", "Z", "-X", "-Y", "-Z"] },
        "line_id": { "type": "string" },
        "loadCaseId": { "type": "string" }
      }
    },
    "generationSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mesh_division", "mesh_density"],
      "properties": {
        "mesh_division": { "type": "integer", "minimum": 1, "maximum": 50 },
        "mesh_density": { "enum": ["coarse", "standard", "fine"] },
        "girder_spacing_override": { "type": "number", "exclusiveMinimum": 0 },
        "materialId": { "type": "string" },
        "sectionId": { "type": "string" }
      }
    },
    "generatedFem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_bridge_id", "generatedAt", "xCount", "yCount", "nodeCount", "memberCount", "supportCount", "loadCount", "summary"],
      "properties": {
        "source_bridge_id": { "type": "string" },
        "generatedAt": { "type": "string" },
        "xCount": { "type": "integer", "minimum": 1 },
        "yCount": { "type": "integer", "minimum": 1 },
        "nodeCount": { "type": "integer", "minimum": 1 },
        "memberCount": { "type": "integer", "minimum": 0 },
        "supportCount": { "type": "integer", "minimum": 1 },
        "loadCount": { "type": "integer", "minimum": 0 },
        "summary": { "type": "object" }
      }
    }
  }
}
