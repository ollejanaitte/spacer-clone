{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spacer-clone.local/schemas/result.schema.json",
  "title": "SPACER Clone MVP Analysis Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["projectId", "schemaVersion", "analysisSummary", "displacements", "reactions", "memberEndForces", "warnings", "errors"],
  "properties": {
    "projectId": { "type": "string" },
    "schemaVersion": { "const": "1.0.0" },
    "analysisSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["analysisType", "status", "startedAt", "finishedAt", "durationMs", "nodeCount", "memberCount", "loadCaseCount", "totalDof", "freeDof", "constrainedDof", "solver"],
      "properties": {
        "analysisType": { "enum": ["linear_static", "eigen", "response_spectrum", "responseSpectrum", "influence_line"] },
        "status": { "enum": ["success", "warning", "failed"] },
        "startedAt": { "type": "string" },
        "finishedAt": { "type": "string" },
        "durationMs": { "type": "number" },
        "nodeCount": { "type": "integer", "minimum": 0 },
        "memberCount": { "type": "integer", "minimum": 0 },
        "loadCaseCount": { "type": "integer", "minimum": 0 },
        "totalDof": { "type": "integer", "minimum": 0 },
        "freeDof": { "type": "integer", "minimum": 0 },
        "constrainedDof": { "type": "integer", "minimum": 0 },
        "solver": { "enum": ["scipy_sparse", "scipy_eigh"] }
      }
    },
    "displacements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["loadCaseId", "nodeId", "ux", "uy", "uz", "rx", "ry", "rz"],
        "properties": {
          "loadCaseId": { "type": "string" },
          "nodeId": { "type": "string" },
          "ux": { "type": "number" },
          "uy": { "type": "number" },
          "uz": { "type": "number" },
          "rx": { "type": "number" },
          "ry": { "type": "number" },
          "rz": { "type": "number" }
        }
      }
    },
    "reactions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["loadCaseId", "nodeId", "fx", "fy", "fz", "mx", "my", "mz", "constrainedDofs"],
        "properties": {
          "loadCaseId": { "type": "string" },
          "nodeId": { "type": "string" },
          "fx": { "type": "number" },
          "fy": { "type": "number" },
          "fz": { "type": "number" },
          "mx": { "type": "number" },
          "my": { "type": "number" },
          "mz": { "type": "number" },
          "constrainedDofs": { "type": "array", "items": { "enum": ["ux", "uy", "uz", "rx", "ry", "rz"] } }
        }
      }
    },
    "memberEndForces": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["loadCaseId", "memberId", "coordinateSystem", "i", "j"],
        "properties": {
          "loadCaseId": { "type": "string" },
          "memberId": { "type": "string" },
          "coordinateSystem": { "const": "local" },
          "i": { "$ref": "#/$defs/endForce" },
          "j": { "$ref": "#/$defs/endForce" }
        }
      }
    },
    "eigenResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["massCaseId", "normalization", "modes"],
      "properties": {
        "massCaseId": { "type": "string" },
        "normalization": { "const": "mass" },
        "totalMassByDirection": {
          "type": "array",
          "items": { "$ref": "#/$defs/directionalValue" }
        },
        "modes": {
          "type": "array",
          "items": { "$ref": "#/$defs/eigenMode" }
        }
      }
    },
    "influenceResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["caseId", "line", "stations", "targets", "targetResults"],
      "properties": {
        "caseId": { "type": "string" },
        "line": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "memberId", "stationCount", "loadDirection", "loadMagnitude"],
          "properties": {
            "id": { "type": "string" },
            "memberId": { "type": "string" },
            "stationCount": { "type": "integer", "minimum": 0 },
            "loadDirection": { "$ref": "#/$defs/vector3" },
            "loadMagnitude": { "type": "number" }
          }
        },
        "stations": {
          "type": "array",
          "items": { "$ref": "#/$defs/influenceStation" }
        },
        "targets": {
          "type": "array",
          "items": { "$ref": "#/$defs/influenceTarget" }
        },
        "targetResults": {
          "type": "array",
          "items": { "$ref": "#/$defs/influenceTargetResult" }
        }
      }
    },
    "warnings": { "type": "array", "items": { "$ref": "#/$defs/message" } },
    "errors": { "type": "array", "items": { "$ref": "#/$defs/message" } }
  },
  "$defs": {
    "endForce": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fx", "fy", "fz", "mx", "my", "mz"],
      "properties": {
        "fx": { "type": "number" },
        "fy": { "type": "number" },
        "fz": { "type": "number" },
        "mx": { "type": "number" },
        "my": { "type": "number" },
        "mz": { "type": "number" }
      }
    },
    "message": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "path", "entityType", "entityId"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "path": { "type": ["string", "null"] },
        "entityType": { "type": ["string", "null"] },
        "entityId": { "type": ["string", "null"] }
      }
    },
    "directionalValue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["direction", "value"],
      "properties": {
        "direction": { "type": "string" },
        "value": { "type": "number" }
      }
    },
    "vector3": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "z"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" }
      }
    },
    "influenceStation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["station", "ratio", "position", "stationIndex"],
      "properties": {
        "station": { "type": "number" },
        "ratio": { "type": "number" },
        "position": { "$ref": "#/$defs/vector3" },
        "stationIndex": { "type": "integer", "minimum": 0 }
      }
    },
    "influenceTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "component"],
      "properties": {
        "id": { "type": "string" },
        "type": { "enum": ["displacement", "reaction", "memberEndForce"] },
        "nodeId": { "type": "string" },
        "memberId": { "type": "string" },
        "component": { "type": "string" },
        "end": { "enum": ["i", "j"] }
      }
    },
    "influenceTargetResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targetId", "values"],
      "properties": {
        "targetId": { "type": "string" },
        "values": { "type": "array", "items": { "type": "number" } }
      }
    },
    "modeShape": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodeId", "ux", "uy", "uz", "rx", "ry", "rz"],
      "properties": {
        "nodeId": { "type": "string" },
        "ux": { "type": "number" },
        "uy": { "type": "number" },
        "uz": { "type": "number" },
        "rx": { "type": "number" },
        "ry": { "type": "number" },
        "rz": { "type": "number" }
      }
    },
    "eigenMode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "modeNo",
        "eigenvalue",
        "circularFrequency",
        "frequency",
        "period",
        "modalMass",
        "participationFactors",
        "effectiveMassRatios",
        "shape"
      ],
      "properties": {
        "modeNo": { "type": "integer", "minimum": 1 },
        "eigenvalue": { "type": "number" },
        "circularFrequency": { "type": "number" },
        "frequency": { "type": "number" },
        "period": { "type": "number" },
        "modalMass": { "type": "number" },
        "participationFactors": {
          "type": "array",
          "items": { "$ref": "#/$defs/directionalValue" }
        },
        "effectiveMassRatios": {
          "type": "array",
          "items": { "$ref": "#/$defs/directionalValue" }
        },
        "effectiveMasses": {
          "type": "array",
          "items": { "$ref": "#/$defs/directionalValue" }
        },
        "cumulativeEffectiveMassRatios": {
          "type": "array",
          "items": { "$ref": "#/$defs/directionalValue" }
        },
        "shape": {
          "type": "array",
          "items": { "$ref": "#/$defs/modeShape" }
        }
      }
    }
  }
}
