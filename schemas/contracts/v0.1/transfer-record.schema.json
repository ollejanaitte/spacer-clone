        "contentChecksum": {
          "$ref": "#/$defs/https://spacer.local/schemas/contracts/v0.1/content-checksum.schema.json"
        },
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "embeddedResourceKey": {
          "type": "string",
          "minLength": 1
        },
        "mediaType": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "documentKind",
        "documentId",
        "revisionId",
        "contentChecksum"
      ],
      "additionalProperties": false,
      "title": "DocumentReference",
      "contractVersion": "0.1.0"
    },
    "https://spacer.local/schemas/contracts/v0.1/transfer-record-artifact-reference.schema.json": {
      "type": "object",
      "properties": {
        "recordId": {
          "type": "string",
          "format": "uuid",
          "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
        },
        "schemaVersion": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
        },
        "contentChecksum": {
          "$ref": "#/$defs/https://spacer.local/schemas/contracts/v0.1/content-checksum.schema.json"
        }
      },
      "required": [
        "recordId",
        "schemaVersion",
        "contentChecksum"
      ],
      "additionalProperties": false,
      "title": "TransferRecordArtifactReference",
      "contractVersion": "0.1.0"
    },
    "https://spacer.local/schemas/contracts/v0.1/policy-reference.schema.json": {
      "type": "object",
      "properties": {
        "policyId": {
          "type": "string",
          "minLength": 1
        },
        "schemaVersion": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
        },
        "contentChecksum": {
          "$ref": "#/$defs/https://spacer.local/schemas/contracts/v0.1/content-checksum.schema.json"
        }
      },
      "required": [
        "policyId",
        "schemaVersion",
        "contentChecksum"
      ],
      "additionalProperties": false,
      "title": "PolicyReference",
      "contractVersion": "0.1.0"
    },
    "https://spacer.local/schemas/contracts/v0.1/json-value.schema.json": {
      "title": "JsonValue",
      "contractVersion": "0.1.0",
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/https://spacer.local/schemas/contracts/v0.1/json-value.schema.json"
          }
        },
        {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "$ref": "#/$defs/https://spacer.local/schemas/contracts/v0.1/json-value.schema.json"
          }
        }
      ]
    },
    "https://spacer.local/schemas/contracts/v0.1/immutable-resource-reference.schema.json": {
      "type": "object",
      "properties": {
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "contentChecksum": {
          "$ref": "#/$defs/https://spacer.local/schemas/contracts/v0.1/content-checksum.schema.json"
        },
        "mediaType": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "uri",
        "contentChecksum"
      ],
      "additionalProperties": false,
      "title": "ImmutableResourceReference",
      "contractVersion": "0.1.0"
    }
  },
  "$id": "https://spacer.local/schemas/contracts/v0.1/transfer-record.schema.json",
  "x-semantic-validation": {
    "scope": "structural-plus-semantic",
    "completeValidator": false,
    "runtimeRequired": true,
    "description": "This JSON Schema validates append-only TransferRecord shape. Exact package/source/target references, first-import baseline invariants, status-dependent targetAfter rules, mapping namespace separation, and decision ID uniqueness require runtime semantic validation.",
    "runtimeRules": [
      "TRANSFER_RECORD_SCHEMA_ID_INVALID",
      "TRANSFER_RECORD_BASELINE_REQUIRED_ON_REIMPORT",
      "TRANSFER_RECORD_TARGET_AFTER_REQUIRED",
      "TRANSFER_RECORD_NAMESPACE_REUSE_FORBIDDEN",
      "TRANSFER_RECORD_DECISION_ID_COLLISION",
      "CONTRACT_SCHEMA_VERSION_MAJOR_UNSUPPORTED"
    ]
  },
  "$comment": "Structural JSON Schema only. Do not treat this document as a complete validator; runtime semantic validation is required where x-semantic-validation.runtimeRequired is true."
}
