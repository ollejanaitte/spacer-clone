{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spacer-clone.local/schemas/project.schema.json",
  "title": "MVP project.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project",
    "units",
    "nodes",
    "materials",
    "sections",
    "members",
    "supports",
    "loadCases",
    "nodalLoads",
    "memberLoads",
    "analysisSettings"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "schemaVersion",
        "description",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "schemaVersion": {
          "const": "1.0.0"
        },
        "description": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "units": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "length",
        "force",
        "moment",
        "modulus",
        "area",
        "inertia"
      ],
      "properties": {
        "length": {
          "const": "m"
        },
        "force": {
          "const": "kN"
        },
        "moment": {
          "const": "kN_m"
        },
        "modulus": {
          "const": "kN_per_m2"
        },
        "area": {
          "const": "m2"
        },
        "inertia": {
          "const": "m4"
        }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "materials": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/material"
      }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/section"
      }
    },
    "members": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/member"
      }
    },
    "supports": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/support"
      }
    },
    "loadCases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/loadCase"
      }
    },
    "nodalLoads": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nodalLoad"
      }
    },
    "memberLoads": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/memberLoad"
      }
    },
    "massCases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/massCase"
      }
    },
    "analysisSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "analysisType",
        "solver",
        "includeShearDeformation",
        "largeDisplacement",
        "tolerance"
      ],
      "properties": {
        "analysisType": {
          "const": "linear_static"
        },
        "solver": {
          "const": "scipy_sparse"
        },
        "includeShearDeformation": {
          "const": false
        },
        "largeDisplacement": {
          "const": false
        },
        "tolerance": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "eigen": {
          "$ref": "#/$defs/eigenAnalysisSettings"
        },
        "influence": {
          "$ref": "#/$defs/influenceAnalysisSettings"
        },
        "responseSpectrum": {
          "$ref": "#/$defs/responseSpectrumAnalysisSettings"
        },
        "timeHistory": {
          "$ref": "#/$defs/timeHistoryAnalysisSettings"
        }
      }
    },
    "groundMotions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/groundMotion"
      }
    },
    "analysisResults": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "timeHistory": {
          "$ref": "#/$defs/timeHistoryResult"
        }
      }
    },
    "liner": {
      "$ref": "#/$defs/projectLinerMetadata"
    },
    "linerTrace": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/linerTraceEntry"
      }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "x",
        "y",
        "z"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        },
        "label": {
          "type": "string"
        }
      }
    },
    "material": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "elasticModulus",
        "shearModulus"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "elasticModulus": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "shearModulus": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "poissonRatio": {
          "type": "number"
        },
        "density": {
          "type": "number"
        }
      }
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "area",
        "iy",
        "iz",
        "j"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "area": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "iy": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "iz": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "j": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "member": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "nodeI",
        "nodeJ",
        "materialId",
        "sectionId"
      ],
      "not": {
        "required": [
          "orientationVector",
          "orientationNode"
        ]
      },
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "nodeI": {
          "type": "string",
          "minLength": 1
        },
        "nodeJ": {
          "type": "string",
          "minLength": 1
        },
        "materialId": {
          "type": "string",
          "minLength": 1
        },
        "sectionId": {
          "type": "string",
          "minLength": 1
        },
        "orientationVector": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "x",
            "y",
            "z"
          ],
          "properties": {
            "x": {
              "type": "number"
            },
            "y": {
              "type": "number"
            },
            "z": {
              "type": "number"
            }
          }
        },
        "orientationNode": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        }
      }
    },
    "support": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "nodeId",
        "ux",
        "uy",
        "uz",
        "rx",
        "ry",
        "rz"
      ],
      "properties": {
        "nodeId": {
          "type": "string",
          "minLength": 1
        },
        "ux": {
          "type": "boolean"
        },
        "uy": {
          "type": "boolean"
        },
        "uz": {
          "type": "boolean"
        },
        "rx": {
          "type": "boolean"
        },
        "ry": {
          "type": "boolean"
        },
        "rz": {
          "type": "boolean"
        }
      }
    },
    "loadCase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "const": "static"
        }
      }
    },
    "nodalLoad": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "loadCaseId",
        "nodeId",
        "fx",
        "fy",
        "fz",
        "mx",
        "my",
        "mz"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "loadCaseId": {
          "type": "string",
          "minLength": 1
        },
        "nodeId": {
          "type": "string",
          "minLength": 1
        },
        "fx": {
          "type": "number"
        },
        "fy": {
          "type": "number"
        },
        "fz": {
          "type": "number"
        },
        "mx": {
          "type": "number"
        },
        "my": {
          "type": "number"
        },
        "mz": {
          "type": "number"
        }
      }
    },
    "memberLoad": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "loadCaseId",
        "memberId",
        "coordinateSystem",
        "type",
        "wx",
        "wy",
        "wz"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "loadCaseId": {
          "type": "string",
          "minLength": 1
        },
        "memberId": {
          "type": "string",
          "minLength": 1
        },
        "coordinateSystem": {
          "enum": [
            "local",
            "global"
          ]
        },
        "type": {
          "const": "uniform"
        },
        "wx": {
          "type": "number"
        },
        "wy": {
          "type": "number"
        },
        "wz": {
          "type": "number"
        }
      }
    },
    "massCase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "method",
        "source",
        "items"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "method": {
          "const": "lumped"
        },
        "source": {
          "const": "manual"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/massItem"
          }
        }
      }
    },
    "eigenAnalysisSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "massCaseId",
        "modeCount"
      ],
      "properties": {
        "massCaseId": {
          "type": "string",
          "minLength": 1
        },
        "modeCount": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "influenceAnalysisSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "caseId",
        "line",
        "targets"
      ],
      "properties": {
        "caseId": {
          "type": "string",
          "minLength": 1
        },
        "line": {
          "$ref": "#/$defs/influenceLineSettings"
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/influenceTarget"
          }
        }
      }
    },
    "influenceLineSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "memberId",
        "stationCount",
        "direction",
        "magnitude"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "memberId": {
          "type": "string",
          "minLength": 1
        },
        "stationCount": {
          "type": "integer",
          "minimum": 2,
          "maximum": 201
        },
        "direction": {
          "$ref": "#/$defs/vector3"
        },
        "magnitude": {
          "type": "number"
        }
      }
    },
    "influenceTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "component"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": [
            "displacement",
            "reaction",
            "memberEndForce"
          ]
        },
        "nodeId": {
          "type": "string",
          "minLength": 1
        },
        "memberId": {
          "type": "string",
          "minLength": 1
        },
        "component": {
          "type": "string",
          "minLength": 1
        },
        "end": {
          "enum": [
            "i",
            "j"
          ]
        }
      }
    },
    "vector3": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y",
        "z"
      ],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        }
      }
    },
    "massItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "nodeId",
        "mx",
        "my",
        "mz",
        "irx",
        "iry",
        "irz"
      ],
      "properties": {
        "nodeId": {
          "type": "string",
          "minLength": 1
        },
        "mx": {
          "type": "number",
          "minimum": 0
        },
        "my": {
          "type": "number",
          "minimum": 0
        },
        "mz": {
          "type": "number",
          "minimum": 0
        },
        "irx": {
          "type": "number",
          "minimum": 0
        },
        "iry": {
          "type": "number",
          "minimum": 0
        },
        "irz": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "responseSpectrumAnalysisSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "modeCount",
        "spectrumCaseId",
        "direction",
        "dampingRatio",
        "targetCumulativeMassRatio",
        "spectrumPoints"
      ],
      "properties": {
        "massCaseId": {
          "type": "string",
          "minLength": 1
        },
        "modeCount": {
          "type": "integer",
          "minimum": 1
        },
        "spectrumCaseId": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "enum": [
            "X",
            "Y",
            "Z"
          ]
        },
        "dampingRatio": {
          "type": "number",
          "minimum": 0
        },
        "combinationMethod": {
          "enum": [
            "SRSS",
            "CQC"
          ]
        },
        "interpolationMethod": {
          "enum": [
            "linear",
            "logLog"
          ]
        },
        "targetCumulativeMassRatio": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "spectrumPoints": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/responseSpectrumPoint"
          }
        }
      }
    },
    "responseSpectrumPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "period",
        "value"
      ],
      "properties": {
        "period": {
          "type": "number",
          "minimum": 0
        },
        "value": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "timeHistoryAnalysisSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "timeStep",
        "duration",
        "beta",
        "gamma"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "method": {
          "enum": [
            "newmark-beta"
          ]
        },
        "timeStep": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "duration": {
          "type": "number",
          "minimum": 0
        },
        "beta": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "gamma": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "damping": {
          "$ref": "#/$defs/timeHistoryDamping"
        },
        "initialConditions": {
          "$ref": "#/$defs/timeHistoryInitialConditions"
        },
        "massCaseId": {
          "type": "string",
          "minLength": 1
        },
        "groundMotionId": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "enum": [
            "X",
            "Y",
            "Z"
          ]
        }
      }
    },
    "timeHistoryDamping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "enum": [
            "rayleigh",
            "modal",
            "constant",
            "userMatrix"
          ]
        },
        "mode1Frequency": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "mode2Frequency": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "targetDampingRatio1": {
          "type": "number",
          "minimum": 0,
          "exclusiveMaximum": 1
        },
        "targetDampingRatio2": {
          "type": "number",
          "minimum": 0,
          "exclusiveMaximum": 1
        },
        "alpha": {
          "type": "number",
          "minimum": 0
        },
        "beta": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "timeHistoryInitialConditions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "displacement": {
          "enum": [
            "zero",
            "fromStatic"
          ]
        },
        "velocity": {
          "enum": [
            "zero",
            "fromStatic"
          ]
        }
      }
    },
    "groundMotion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "direction",
        "timeStep",
        "duration",
        "unit",
        "samples"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "enum": [
            "X",
            "Y",
            "Z"
          ]
        },
        "timeStep": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "duration": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "unit": {
          "enum": [
            "m/s2",
            "gal"
          ]
        },
        "samples": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    },
    "envelopeExtremum": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "time"
      ],
      "properties": {
        "value": {
          "type": "number"
        },
        "time": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "envelopePair": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max",
        "min"
      ],
      "properties": {
        "max": {
          "$ref": "#/$defs/envelopeExtremum"
        },
        "min": {
          "$ref": "#/$defs/envelopeExtremum"
        }
      }
    },
    "timeHistoryResultMemberForces": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "N": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "Vy": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "Vz": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "Mx": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "My": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "Mz": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    },
    "timeHistoryResultMeta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "analysisId",
        "status",
        "method",
        "timeStep",
        "duration",
        "beta",
        "gamma",
        "damping",
        "groundMotions",
        "sampleCount"
      ],
      "properties": {
        "analysisId": {
          "type": "string"
        },
        "status": {
          "enum": [
            "success",
            "warning",
            "failed"
          ]
        },
        "method": {
          "type": "string"
        },
        "timeStep": {
          "type": "number"
        },
        "duration": {
          "type": "number"
        },
        "beta": {
          "type": "number"
        },
        "gamma": {
          "type": "number"
        },
        "damping": {
          "type": "object"
        },
        "groundMotions": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "sampleCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "projectLinerMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "sourceRevision",
        "linerModelId",
        "coordinatePolicyId",
        "intermediateSchemaVersion"
      ],
      "properties": {
        "schemaVersion": {
          "type": "string",
          "minLength": 1
        },
        "sourceRevision": {
          "type": "string",
          "minLength": 1
        },
        "linerModelId": {
          "type": "string",
          "minLength": 1
        },
        "coordinatePolicyId": {
          "type": "string",
          "minLength": 1
        },
        "intermediateSchemaVersion": {
          "const": "0.2.0"
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "alignmentId": {
